NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
# Smart Picker (AI shoe recommendation) — packyapi.com, OpenAI-compatible.
# The API key is the real secret key value (NOT the token name "sneakerfeature").
# Base URL: the OpenAI-compatible base, e.g. https://www.packyapi.com/v1
# (give just the host and the app appends /v1 automatically).
# Both naming conventions are accepted: PACKYAPI_* or PACKY_API_*.
PACKYAPI_API_KEY=
PACKYAPI_BASE_URL=https://www.packyapi.com/v1
PACKYAPI_MODEL=claude-haiku-4-5-20251001
# Bocha (博查) Web Search — lets the AI fetch general knowledge (injury recovery
# principles, position-specific play tips, term explanations) when the catalog
# doesn't cover the user's question. Register at https://open.bochaai.com
# (supports 支付宝/微信 payment). Leave blank to disable web search; the AI
# falls back to catalog-only behavior, identical to before this feature.
BOCHA_API_KEY=
# --- Local blogger-review pipeline (scripts/blogger-reviews/*) ---------------
# Reuses the vars above: NEXT_PUBLIC_SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY,
# PACKYAPI_API_KEY/PACKYAPI_BASE_URL/PACKYAPI_MODEL. The scripts read .env.local
# (then .env) — they do NOT run on the server. (Link-finding uses yt-dlp's own
# bilisearch/ytsearch, so no Bocha key is needed for the pipeline.)
# External CLIs the ingest script shells out to (install separately, NOT npm):
#   yt-dlp  (search + YouTube subtitles + uploader)  https://github.com/yt-dlp/yt-dlp
#   BBDown  (Bilibili subtitles)                     https://github.com/nilaoda/BBDown
#   ffmpeg  (required by BBDown and by yt-dlp subtitle conversion)
# YouTube blocks anonymous yt-dlp; set ONE of these to enable YouTube (you must
# be logged into YouTube in that browser). Bilibili works without them.
# YTDLP_COOKIES_FROM_BROWSER=firefox   (or chrome/safari/edge/brave)
# YTDLP_COOKIES_FILE=/absolute/path/to/cookies.txt
# Optional override for the subtitle scratch dir (default /tmp/bloggerrev):
# BLOGGER_REVIEWS_TMP_DIR=/tmp/bloggerrev
# Human verification (in-site slide-to-verify). OPTIONAL: a dedicated HMAC secret
# for signing verification tokens. If unset, the app falls back to
# SUPABASE_SERVICE_ROLE_KEY (always present in production), so no config is needed.
HUMAN_VERIFY_SECRET=
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Auth "Send Email" hook (OPTIONAL) — route auth emails through Resend's HTTP API
# instead of Supabase SMTP for a faster, more reliable send. Only needed if you
# enable the hook in Supabase. See docs/send-email-hook.md.
# Secret generated by Supabase when you create the hook (format: v1,whsec_...).
SEND_EMAIL_HOOK_SECRET=
RESEND_API_KEY=
# Sender shown on auth emails (must be a verified domain/sender in Resend).
EMAIL_FROM="sneakerfeature <noreply@snkrfeature.com>"
